# Environment Variables Template
# Copy this file to .env and fill in your actual credentials

# SMTP configuration for sending emails (e.g., DreamHost as used in this project)
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-app-specific-password

# List of emails that will receive the feedback summaries (comma-separated)
RECIPIENT_EMAILS=admin@example.com,manager@example.com

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/your-db-name?retryWrites=true&w=majority

# The port the server will run on
PORT=3001
